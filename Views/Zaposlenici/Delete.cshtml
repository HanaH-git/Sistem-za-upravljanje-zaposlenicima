@model Aplikacija.Models.Zaposlenik

@{
    ViewData["Title"] = "Delete";
}

<h2>Obriši zaposlenika</h2>

<h4>Da li ste sigurni da želite obrisati ovog zaposlenika?</h4>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Ime</dt>
        <dd class="col-sm-10">@Model.Ime</dd>

        <dt class="col-sm-2">Prezime</dt>
        <dd class="col-sm-10">@Model.Prezime</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Odjel</dt>
        <dd class="col-sm-10">@Model.Odjel?.Naziv</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="ZaposlenikId" />
        <button type="submit" class="btn btn-danger">Obriši</button>
        <a asp-action="Index" class="btn btn-secondary">Nazad</a>
    </form>
</div>