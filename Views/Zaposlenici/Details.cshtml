@using Microsoft.AspNetCore.Mvc.Rendering
@model Aplikacija.Models.Zaposlenik

@{
    ViewData["Title"] = "Details";
}

<h2>Detalji zaposlenika</h2>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Ime</dt>
        <dd class="col-sm-9">@Model.Ime</dd>

        <dt class="col-sm-3">Prezime</dt>
        <dd class="col-sm-9">@Model.Prezime</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Plata (BAM)</dt>
        <dd class="col-sm-9">@Model.PlataMonthly</dd>

        <dt class="col-sm-3">Datum zaposlenja</dt>
        <dd class="col-sm-9">@Model.DatumZaposlenja.ToShortDateString()</dd>

        <dt class="col-sm-3">Odjel</dt>
        <dd class="col-sm-9">@Model.Odjel?.Naziv</dd>
    </dl>
</div>

<hr />

<h4>Konverzija plate</h4>

<form asp-action="Details" method="get">
    <input type="hidden" name="id" value="@Model.ZaposlenikId" />

    <div class="mb-3">
        <label class="form-label">Odaberi valutu</label>
        <select name="valuta" class="form-control">
            <option value="">-- Odaberi valutu --</option>
            <option value="EUR">EUR</option>
            <option value="USD">USD</option>
            <option value="GBP">GBP</option>
            <option value="CHF">CHF</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Prikaži konverziju</button>
</form>

@if (ViewBag.KonvertovanaPlata != null)
{
    <div class="alert alert-info mt-3">
        Plata u valuti @ViewBag.OdabranaValuta: <strong>@ViewBag.KonvertovanaPlata</strong>
    </div>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ZaposlenikId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Nazad</a>
</div>